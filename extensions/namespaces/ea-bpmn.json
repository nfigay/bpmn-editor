{
  "name": "EnterpriseArchitect",
  "uri": "http://www.sparxsystems.com/profiles/BPMN/1.0",
  "prefix": "ea",
  "category": "A",
  "label": "Sparx EA",
  "description": "Sparx Enterprise Architect BPMN profile extensions — import/export",
  "direction": "import-export",
  "types": [
    {
      "name": "Element",
      "superClass": ["Element"],
      "meta": { "allowedIn": ["*"] },
      "properties": [
        { "name": "alias",   "isAttr": true, "type": "String",
          "description": "EA element alias — used as stable ID for merge" },
        { "name": "package", "isAttr": true, "type": "String",
          "description": "EA package path where the element resides" },
        { "name": "guid",    "isAttr": true, "type": "String",
          "description": "EA internal GUID — authoritative merge key" },
        { "name": "status",  "isAttr": true, "type": "String",
          "description": "EA element status (Proposed, Approved, etc.)" }
      ]
    },
    {
      "name": "TaggedValue",
      "superClass": ["Element"],
      "meta": { "allowedIn": ["*"] },
      "properties": [
        { "name": "tag",   "isAttr": true, "type": "String",
          "description": "Tagged value name" },
        { "name": "value", "isAttr": true, "type": "String",
          "description": "Tagged value content" }
      ]
    },
    {
      "name": "DiagramInfo",
      "superClass": ["Element"],
      "meta": { "allowedIn": ["*"] },
      "properties": [
        { "name": "diagramGuid", "isAttr": true, "type": "String" },
        { "name": "diagramName", "isAttr": true, "type": "String" },
        { "name": "stereotype",  "isAttr": true, "type": "String" }
      ]
    }
  ]
}
