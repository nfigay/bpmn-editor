{
  "name": "ARIS",
  "uri": "http://www.softwareag.com/aris/bpmn/1.0",
  "prefix": "aris",
  "category": "A",
  "label": "ARIS",
  "description": "Software AG ARIS BPMN export extensions — import/export",
  "direction": "import-export",
  "types": [
    {
      "name": "Object",
      "superClass": ["Element"],
      "meta": { "allowedIn": ["*"] },
      "properties": [
        { "name": "objectId",   "isAttr": true, "type": "String",
          "description": "ARIS object identifier — primary merge key" },
        { "name": "objectName", "isAttr": true, "type": "String",
          "description": "ARIS object name — secondary merge key if ID absent" },
        { "name": "objectType", "isAttr": true, "type": "String",
          "description": "ARIS object type code" },
        { "name": "database",   "isAttr": true, "type": "String",
          "description": "ARIS database path" },
        { "name": "group",      "isAttr": true, "type": "String",
          "description": "ARIS group path" }
      ]
    },
    {
      "name": "Attribute",
      "superClass": ["Element"],
      "meta": { "allowedIn": ["*"] },
      "properties": [
        { "name": "attrTypeNum", "isAttr": true, "type": "String",
          "description": "ARIS attribute type number" },
        { "name": "attrName",    "isAttr": true, "type": "String",
          "description": "ARIS attribute name" },
        { "name": "value",       "isAttr": true, "type": "String" },
        { "name": "language",    "isAttr": true, "type": "String",
          "description": "Language code (e.g. en, fr, de)" }
      ]
    },
    {
      "name": "KPI",
      "superClass": ["Element"],
      "meta": { "allowedIn": ["*"] },
      "properties": [
        { "name": "kpiId",    "isAttr": true, "type": "String" },
        { "name": "kpiName",  "isAttr": true, "type": "String" },
        { "name": "value",    "isAttr": true, "type": "String" },
        { "name": "unit",     "isAttr": true, "type": "String" },
        { "name": "source",   "isAttr": true, "type": "String" }
      ]
    }
  ]
}
