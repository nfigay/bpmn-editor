{
  "id": "profile-coc-avionics-ea-l2",
  "label": "CoC Avionics — EA — L2",
  "description": "Avionics CoC modelled in Sparx EA at L2 maturity (DO-178C / DO-254)",

  "activationConditions": {
    "businessContext.systemType": "CoC",
    "lifecycle.maturity": ["L2", "L3"],
    "technicalRealization.softwareProduct": "Sparx Enterprise Architect"
  },

  "namespaces": ["semarch", "do178c", "ea"],

  "fields": [
    {
      "id": "semarch:cocRef",
      "label": "Centre of Competence",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "cocRef",
      "appliesTo": ["bpmn:Process", "bpmn:Task", "bpmn:UserTask",
                    "bpmn:ServiceTask", "bpmn:CallActivity", "bpmn:SubProcess"],
      "type": "string",
      "required": true,
      "group": "Traceability",
      "hint": "Owning Centre of Competence identifier"
    },
    {
      "id": "semarch:stdRef",
      "label": "Standard Reference",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "stdRef",
      "appliesTo": ["*"],
      "type": "string",
      "required": false,
      "group": "Traceability",
      "hint": "e.g. DO-178C §5.1, DO-254 §5.2"
    },
    {
      "id": "semarch:maturity",
      "label": "Maturity Level",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "maturity",
      "appliesTo": ["bpmn:Process"],
      "type": "enum",
      "values": ["L1", "L2", "L3", "L4"],
      "required": false,
      "group": "Traceability"
    },
    {
      "id": "semarch:platformRef",
      "label": "EA Reference",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "platformRef",
      "appliesTo": ["bpmn:Process", "bpmn:Task", "bpmn:CallActivity"],
      "type": "string",
      "required": false,
      "group": "Platform",
      "hint": "EA://GUID-{guid} — populated automatically on EA import"
    },
    {
      "id": "semarch:bmsRef",
      "label": "BMS Reference",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "bmsRef",
      "appliesTo": ["bpmn:Process"],
      "type": "string",
      "required": false,
      "group": "Traceability",
      "hint": "ARIS://BMS/... — parent BMS process"
    },
    {
      "id": "do178c:dal",
      "label": "Design Assurance Level",
      "namespace": "do178c",
      "targetType": "do178c:SoftwareLevel",
      "targetAttr": "dal",
      "appliesTo": ["bpmn:Process", "bpmn:Task", "bpmn:UserTask",
                    "bpmn:ServiceTask", "bpmn:SubProcess"],
      "type": "enum",
      "values": ["A", "B", "C", "D", "E"],
      "required": true,
      "group": "DO-178C",
      "hint": "Software DAL per DO-178C §2.2"
    },
    {
      "id": "do178c:verificationCriteria",
      "label": "Verification Criteria",
      "namespace": "do178c",
      "targetType": "do178c:SoftwareLevel",
      "targetAttr": "verificationCriteria",
      "appliesTo": ["bpmn:Task", "bpmn:UserTask", "bpmn:ServiceTask"],
      "type": "enum",
      "values": ["MC/DC", "decision", "statement", "none"],
      "required": false,
      "group": "DO-178C"
    },
    {
      "id": "do178c:phase",
      "label": "Lifecycle Phase",
      "namespace": "do178c",
      "targetType": "do178c:Lifecycle",
      "targetAttr": "phase",
      "appliesTo": ["bpmn:Process"],
      "type": "enum",
      "values": ["planning", "development", "verification", "SCM", "QA"],
      "required": false,
      "group": "DO-178C"
    },
    {
      "id": "ea:alias",
      "label": "EA Alias",
      "namespace": "ea",
      "targetType": "ea:Element",
      "targetAttr": "alias",
      "appliesTo": ["bpmn:Process", "bpmn:Task"],
      "type": "string",
      "required": false,
      "group": "Platform (EA)",
      "hint": "Populated automatically on EA import — edit with care"
    }
  ],

  "rules": [
    {
      "id": "do178c/dal-required-process",
      "description": "All processes must declare a DAL",
      "severity": "warning",
      "type": "required",
      "field": "do178c:dal",
      "appliesTo": ["bpmn:Process"]
    },
    {
      "id": "do178c/dal-required-task",
      "description": "All tasks must declare a DAL",
      "severity": "info",
      "type": "required",
      "field": "do178c:dal",
      "appliesTo": ["bpmn:Task", "bpmn:UserTask", "bpmn:ServiceTask"]
    },
    {
      "id": "semarch/coc-ref-required",
      "description": "CoC reference required on all processes",
      "severity": "info",
      "type": "required",
      "field": "semarch:cocRef",
      "appliesTo": ["bpmn:Process"]
    },
    {
      "id": "do178c/mc-dc-requires-dal-a",
      "description": "MC/DC verification only required for DAL-A",
      "severity": "info",
      "type": "conditional-required",
      "condition": { "field": "do178c:dal", "value": "A" },
      "requires": "do178c:verificationCriteria",
      "appliesTo": ["bpmn:Task", "bpmn:UserTask"]
    }
  ]
}
