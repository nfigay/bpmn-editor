{
  "id": "profile-bms-aris-l1",
  "label": "BMS — ARIS — L1",
  "description": "Corporate BMS in ARIS at L1 maturity — minimal semarch traceability",

  "activationConditions": {
    "businessContext.systemType": "BMS",
    "lifecycle.maturity": ["L1", "L2"]
  },

  "namespaces": ["semarch", "aris"],

  "fields": [
    {
      "id": "semarch:cocRef",
      "label": "Domain / Owner",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "cocRef",
      "appliesTo": ["bpmn:Process", "bpmn:Task"],
      "type": "string",
      "required": false,
      "group": "Governance",
      "hint": "Owning domain or department"
    },
    {
      "id": "semarch:stdRef",
      "label": "Standard Reference",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "stdRef",
      "appliesTo": ["*"],
      "type": "string",
      "required": false,
      "group": "Governance",
      "hint": "e.g. ISO 9001/8.3, EN 9100/7.5"
    },
    {
      "id": "semarch:status",
      "label": "Process Status",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "status",
      "appliesTo": ["bpmn:Process"],
      "type": "enum",
      "values": ["Draft", "Review", "Approved", "Deprecated"],
      "required": false,
      "group": "Governance"
    },
    {
      "id": "semarch:version",
      "label": "Version",
      "namespace": "semarch",
      "targetType": "semarch:Meta",
      "targetAttr": "version",
      "appliesTo": ["bpmn:Process"],
      "type": "string",
      "required": false,
      "group": "Governance"
    },
    {
      "id": "aris:objectId",
      "label": "ARIS Object ID",
      "namespace": "aris",
      "targetType": "aris:Object",
      "targetAttr": "objectId",
      "appliesTo": ["bpmn:Process", "bpmn:Task"],
      "type": "string",
      "required": false,
      "group": "Platform (ARIS)",
      "hint": "Populated automatically on ARIS import"
    },
    {
      "id": "aris:group",
      "label": "ARIS Group Path",
      "namespace": "aris",
      "targetType": "aris:Object",
      "targetAttr": "group",
      "appliesTo": ["bpmn:Process"],
      "type": "string",
      "required": false,
      "group": "Platform (ARIS)"
    }
  ],

  "rules": [
    {
      "id": "bms/name-required",
      "description": "All BMS processes must have a name",
      "severity": "error",
      "type": "required",
      "field": "bpmn:name",
      "appliesTo": ["bpmn:Process"]
    },
    {
      "id": "bms/status-approved-requires-std",
      "description": "Approved processes should reference their governing standard",
      "severity": "info",
      "type": "conditional-required",
      "condition": { "field": "semarch:status", "value": "Approved" },
      "requires": "semarch:stdRef",
      "appliesTo": ["bpmn:Process"]
    }
  ]
}
