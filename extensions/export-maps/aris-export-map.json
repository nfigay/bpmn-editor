{
  "id": "aris-export-map",
  "label": "Semantic Mediator → ARIS",
  "targetProduct": "ARIS",
  "targetNamespacePrefix": "aris",
  "addMissing": true,
  "strip": ["ea:", "camunda:", "do178c:", "ecss:"],
  "preserve": ["semarch:", "aris:"],

  "mappings": [
    {
      "sourceType": "semarch:Meta",
      "sourceAttr": "platformRef",
      "targetType": "aris:Object",
      "targetAttr": "objectId",
      "transform": "strip-prefix:ARIS://ID-"
    },
    {
      "sourceType": "semarch:Meta",
      "sourceAttr": "cocRef",
      "targetType": "aris:Object",
      "targetAttr": "objectName",
      "transform": "none"
    },
    {
      "sourceType": "semarch:Meta",
      "sourceAttr": "bmsRef",
      "targetType": "aris:Object",
      "targetAttr": "group",
      "transform": "strip-prefix:ARIS://"
    },
    {
      "sourceType": "semarch:Meta",
      "sourceAttr": "stdRef",
      "targetType": "aris:Attribute",
      "targetAttr": "tag=stdRef",
      "transform": "none"
    },
    {
      "sourceType": "semarch:Meta",
      "sourceAttr": "maturity",
      "targetType": "aris:Attribute",
      "targetAttr": "tag=maturity",
      "transform": "none"
    }
  ]
}
